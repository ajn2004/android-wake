<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#FFFFFFFF">

    <TextView
        android:id="@+id/widget_network_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#FF111111"
        android:text="Approved Network" />

    <Button
        android:id="@+id/widget_wake_all_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/widget_wake_all"
        android:textAllCaps="false" />

    <ListView
        android:id="@+id/widget_machine_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:divider="#FFE6E6E6"
        android:dividerHeight="1dp"
        android:scrollbars="vertical" />

    <TextView
        android:id="@+id/widget_empty_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="13sp"
        android:textColor="#FF555555"
        android:text="@string/widget_no_machines"
        android:paddingTop="8dp" />

</LinearLayout>
